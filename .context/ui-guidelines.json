{
  "meta": {
    "name": "eos-healthcare-system",
    "stack": {
      "framework": "Next.js",
      "language": "TypeScript",
      "styling": "Tailwind CSS",
      "animations": "Motion"
    },
    "principles": [
      "Mathematical harmony (4px/8px baseline)",
      "State-driven UI (Enabled, Pressed, Processing)",
      "High-contrast clinical readability",
      "Woodsmoke neutral scaling",
      "Pixel-perfect component sizing"
    ]
  },
  "design_tokens": {
    "borderRadius": {
      "sm": "rounded-md",
      "default": "rounded-xl",
      "input": "rounded-2xl",
      "card": "rounded-[24px]"
    },
    "spacing": {
      "1": "4px",
      "2": "8px",
      "3": "12px",
      "4": "16px",
      "6": "24px",
      "8": "32px",
      "10": "40px",
      "12": "48px",
      "14": "56px"
    },
    "typography": {
      "fontFamily": "Aeonik",
      "scales": {
        "h1-h3": "tracking-[-0.02em]",
        "lineHeights": "Must be divisible by 4px"
      }
    },
    "colors": {
      "brand": {
        "primary": "#2A52BE",
        "night": "#131313",
        "onyx": "#3C3C3C",
        "silver": "#B5B5B5",
        "white_smoke": "#F3F3F3"
      },
      "woodsmoke": {
        "50": "#FAFAFA",
        "100": "#F5F5F5",
        "200": "#E6E6E6",
        "500": "#727272",
        "800": "#272727",
        "900": "#131313"
      }
    },
    "iconography": {
      "sizes": {
        "sm": "w-4 h-4",
        "md": "w-5 h-5",
        "lg": "w-6 h-6"
      },
      "strokeWidth": "stroke-[1.5px]"
    }
  },
  "layout_system": {
    "grid_pattern": {
      "desktop": "grid-cols-12 gap-6 max-w-[1440px] px-[80px]",
      "tablet": "grid-cols-8 gap-6 max-w-[664px]",
      "mobile": "grid-cols-4 gap-4 px-2"
    },
    "sidebar": {
      "width": "w-[264px]",
      "padding": "px-6 py-9",
      "item_height": "h-[48px]",
      "behavior": "persistent on desktop, collapsible on tablet"
    }
  },
  "components": {
    "buttons": {
      "variants": [
        "contained",
        "outlined",
        "texted"
      ],
      "states": [
        "enabled",
        "disabled",
        "hover",
        "pressed",
        "processing"
      ],
      "rules": {
        "height": "h-[48px]",
        "borderRadius": "rounded-xl",
        "borderWidth": "border-[1.5px]",
        "paddingTextOnly": "px-[30px]",
        "paddingWithIcon": "px-6 gap-1"
      }
    },
    "forms": {
      "types": [
        "text_field",
        "single_select",
        "multiselect"
      ],
      "states": [
        "static",
        "filled",
        "disabled",
        "hover",
        "active",
        "error"
      ],
      "rules": {
        "height": "h-[56px]",
        "borderRadius": "rounded-2xl",
        "padding": "px-4",
        "iconGap": "gap-5",
        "errorState": "Border becomes red, triggers 4px gap to helper text"
      }
    },
    "file_upload": {
      "structure": [
        "DropArea",
        "UploadingProgress",
        "UploadedFileView"
      ],
      "rules": {
        "dropAreaBorder": "border border-dashed border-woodsmoke-200",
        "progressBarHeight": "h-1",
        "fileCardBackground": "bg-[#F3F3F3]",
        "fileCardRadius": "rounded-xl"
      }
    }
  },
  "recommended_libraries": {
    "ui_primitives": {
      "name": "Radix UI",
      "usage": "Headless accessible foundations for selects, dropdowns, and dialogs."
    },
    "variants": {
      "name": "class-variance-authority (cva)",
      "usage": "Perfect for mapping EOS's strict Button and Input states (Enabled, Hover, Pressed)."
    },
    "class_merge": {
      "name": "tailwind-merge & clsx",
      "usage": "Safely combining utility classes without conflicts."
    },
    "animations": {
      "name": "Motion",
      "usage": "Handling the 'Processing' spinner transitions and sidebar collapse animations."
    }
  },
  "ai_enforcement_rules": {
    "avoid": [
      "Using arbitrary h-10 or h-12 sizes for forms (MUST be 56px / h-[56px])",
      "Using standard shadcn button heights (MUST be 48px / h-[48px])",
      "Using true black #000000 (MUST use woodsmoke-900 / #131313)",
      "Inventing random padding values (MUST stick to 4px/8px scale)"
    ],
    "enforce": [
      "Wrap icons in explicit sizing containers (w-5 h-5)",
      "Use cva to handle the specific EOS visual states",
      "Ensure all inputs show label and placeholder correctly centered vertically within the 56px height"
    ]
  }
}